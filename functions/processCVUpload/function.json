{
  "bindings": [
    {
      "type": "blobTrigger",
      "name": "myBlob",
      "path": "cvs/{jobId}/{candidateId}",
      "connection": "BLOB_STORAGE_CONNECTION_STRING",
      "direction": "in"
    },
    {
      "type": "signalR",
      "name": "signalRMessages",
      "hubName": "aptusHub",
      "direction": "out",
      "connectionStringSetting": "SIGNALR_CONNECTION_STRING"
    }
  ]
}
