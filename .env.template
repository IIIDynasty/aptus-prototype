# ============================================
# APTUS MVP — Azure Environment Variables Template
# ============================================
# Copy this file to .env and fill in your actual Azure connection strings
# Never commit .env to version control!

# ============================================
# AZURE COSMOS DB
# ============================================
# Get these values from Azure Portal > Cosmos DB > Keys
COSMOS_DB_ENDPOINT=https://YOUR_COSMOS_ACCOUNT.documents.azure.com:443/
COSMOS_DB_KEY=YOUR_COSMOS_DB_PRIMARY_KEY

# ============================================
# AZURE BLOB STORAGE
# ============================================
# Get these values from Azure Portal > Storage Account > Access Keys
BLOB_STORAGE_ACCOUNT_NAME=YOUR_STORAGE_ACCOUNT_NAME
BLOB_STORAGE_ACCOUNT_KEY=YOUR_STORAGE_ACCOUNT_KEY
BLOB_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_STORAGE_ACCOUNT_NAME;AccountKey=YOUR_STORAGE_ACCOUNT_KEY;EndpointSuffix=core.windows.net

# ============================================
# AZURE SIGNALR SERVICE
# ============================================
# Get this from Azure Portal > SignalR Service > Keys
SIGNALR_CONNECTION_STRING=Endpoint=https://YOUR_SIGNALR_NAME.service.signalr.net;AccessKey=YOUR_ACCESS_KEY;Version=1.0;

# ============================================
# AZURE FUNCTIONS
# ============================================
# Your Azure Functions app URL (create this after setting up Functions)
AZURE_FUNCTIONS_URL=https://YOUR_FUNCTION_APP.azurewebsites.net

# ============================================
# GROQ AI API (Free - No credit card required)
# ============================================
# Get this free from https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY

# ============================================
# RESEND EMAIL API
# ============================================
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
